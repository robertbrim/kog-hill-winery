---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Thank You | Kog Hill Winery">
  <div class="thankyou-wrapper">
    <section class="card thankyou-card">
      <div class="check">✓</div>
      <h1>Thank you.</h1>
      <p>
        Your wholesale inquiry has been received. We'll be in touch soon with availability and pricing.
      </p>
      <a class="button" href="/">Return home</a>
    </section>
  </div>
</BaseLayout>

<style>
  .thankyou-wrapper {
    max-width: 560px;
    margin: 60px auto;
  }

  .thankyou-card {
    text-align: center;
    padding: 56px 48px;
  }

  .check {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--wine);
    color: white;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  h1 {
    font-size: 36px;
    color: var(--wine);
    margin: 0 0 14px 0;
  }

  p {
    font-size: 17px;
    color: #555;
    line-height: 1.6;
    margin: 0 0 32px 0;
  }
</style>
