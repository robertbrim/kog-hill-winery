---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCalendarEvents } from "../lib/calendar.js";

function toDate(value) {
  if (!value) return null;
  const d = new Date(value);
  return Number.isNaN(d.getTime()) ? null : d;
}

function safeText(value) {
  return typeof value === "string" ? value : "";
}

function formatEvent(e) {
  const title = safeText(e.title ?? e.summary ?? e.name ?? "Event");
  const location = safeText(e.location ?? e.where ?? "");

  const start =
    toDate(e.start ?? e.startDate ?? e.startTime ?? e.dtstart ?? e.begin) ?? null;
  const end =
    toDate(e.end ?? e.endDate ?? e.endTime ?? e.dtend ?? e.finish) ?? null;

  const timeZone = "America/New_York";

  const monthShort = start
    ? new Intl.DateTimeFormat("en-US", { month: "short", timeZone }).format(start)
    : "";
  const day = start
    ? new Intl.DateTimeFormat("en-US", { day: "2-digit", timeZone }).format(start)
    : "";

  let timeRange = "";
  if (start) {
    const startTime = new Intl.DateTimeFormat("en-US", {
      hour: "numeric",
      minute: "2-digit",
      timeZone,
    }).format(start);

    if (end) {
      const endTime = new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
        timeZone,
      }).format(end);

      timeRange = `${startTime} to ${endTime}`;
    } else {
      timeRange = startTime;
    }
  }

  return {
    title,
    location: location || null,
    monthShort,
    day,
    timeRange: timeRange || "",
    start: start ? start.toISOString() : null,
  };
}

const raw = await getCalendarEvents();
const rawArray = Array.isArray(raw) ? raw : (raw?.events ?? []);
const allEvents = rawArray.map(formatEvent);

const squareUrl = "https://kog-hill-winery.square.site/";
---

<BaseLayout title="Kog Hill Winery" description="Kog Hill Winery pours small-batch handcrafted wines at events across Pennsylvania. Find us at local festivals and markets, or order online through our store.">
  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="heroGrid">
        <div>
          <p class="eyebrow">Kog Hill Winery</p>
          <h1>We pour at events. You order online.</h1>
          <p class="lead">
            Find us at festivals, markets, and community events. Order anytime through our online store.
          </p>

          <div class="actions">
            <a class="button" href="/events">Find Us This Month</a>
            <a class="button button-outline" href={squareUrl} target="_blank" rel="noopener noreferrer">
              Shop Online
            </a>
          </div>
        </div>

        <aside class="card nextCard" aria-label="Next events">
          <h2 class="h2">Next events</h2>

          <ol class="eventList" id="home-event-list">
            <li class="eventRow">
              <p class="muted">Loading upcoming events…</p>
            </li>
          </ol>

          <div class="nextActions">
            <a class="button button-outline" href="/events">See all events</a>
          </div>
        </aside>
      </div>
    </section>

    <!-- WHAT NOW -->
    <section class="section">
      <div class="threeCol">
        <div class="card">
          <h2 class="h2">Events</h2>
          <p class="p">
            Our calendar is <a href="/events">always current</a>. Tap an event to see full details.
          </p>
          <a class="button" href="/events">View events</a>
        </div>

        <div class="card">
          <h2 class="h2">Shop online</h2>
          <p class="p">Order through our Square store for pickup or shipping.</p>
          <a class="button" href={squareUrl} target="_blank" rel="noopener noreferrer">
            Shop Online
          </a>
        </div>

        <div class="card">
          <h2 class="h2">Wholesale</h2>
          <p class="p">
            Interested in carrying Kog Hill at your shop or venue? We offer wholesale availability by request.
          </p>
          <a class="button" href="/wholesale">Wholesale details</a>
        </div>
      </div>
    </section>

    <!-- ABOUT TEASER -->
    <section class="section alt">
      <div class="twoCol">
        <div>
          <h2 class="h2">About Kog Hill</h2>
          <p class="p">
            Kog Hill began in 2002 and was purchased in 2022 by Julie and Bob. We kept what worked, modernized the rest,
            and focused on unique wines that small producers do best.
          </p>
          <p class="p">
            Closing the tasting room was strategic. Today we pour at events and keep ordering simple online while we
            look for the right future home.
          </p>

          <div class="actions">
            <a class="button" href="/about">Read more</a>
            <a class="button button-outline" href="/events">Find us</a>
          </div>
        </div>

        <div class="card stat">
          <strong>Where to find us</strong>
          <div class="muted">Unique wines you cannot typically find elsewhere</div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ allEvents }}>
    (function () {
      const now = new Date();

      const upcoming = allEvents
        .filter((e) => e.start && new Date(e.start) >= now)
        .sort((a, b) => new Date(a.start) - new Date(b.start))
        .slice(0, 3);

      const list = document.getElementById("home-event-list");
      if (!list) return;

      if (upcoming.length === 0) {
        list.innerHTML =
          '<li class="eventRow"><p class="muted">No upcoming events are listed right now. Check back soon.</p></li>';
        return;
      }

      list.innerHTML = upcoming
        .map(
          (e) => `
          <li class="eventRow">
            <div class="eventDate">
              <span class="md">${e.monthShort}</span>
              <span class="dy">${e.day}</span>
            </div>
            <div class="eventInfo">
              <div class="eventName">${e.title}</div>
              <div class="eventMeta">
                ${e.timeRange ? `<span>${e.timeRange}</span>` : ""}
                ${e.timeRange && e.location ? `<span class="dot">\u00b7</span>` : ""}
                ${e.location ? `<span>${e.location}</span>` : ""}
              </div>
            </div>
          </li>`
        )
        .join("");
    })();
  </script>

  <style>
    /* Page layout only. Colors and buttons come from BaseLayout. */

    .hero { padding: 18px 0 10px; }

    .heroGrid {
      display: grid;
      grid-template-columns: 1.25fr 0.9fr;
      gap: 22px;
      align-items: start;
    }

    .eyebrow {
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 12px;
      opacity: 0.75;
      margin: 0 0 10px;
    }

    h1 {
      font-size: 46px;
      line-height: 1.05;
      margin: 0 0 10px;
    }

    .lead {
      font-size: 18px;
      opacity: 0.85;
      max-width: 60ch;
      margin: 0 0 18px;
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    /* Next events card */
    .nextCard { padding: 18px 20px 14px; }
    .nextCard .h2 { font-size: 16px; margin: 0 0 14px; text-align: center; }

    .eventList {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }

    .nextActions { margin-top: 14px; text-align: center; }

    /* Section grid */
    .section { padding: 18px 0; }
    .section.alt { background: var(--bg-alt, #f5f0eb); padding: 24px 16px; border-radius: 12px; margin: 8px 0; }

    .threeCol {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .twoCol {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 24px;
      align-items: center;
    }

    .h2 { font-size: 20px; margin: 0 0 8px; }
    .p { font-size: 15px; margin: 0 0 14px; opacity: 0.85; max-width: 50ch; }

    .stat { text-align: center; padding: 24px; }
    .stat strong { font-size: 20px; display: block; margin-bottom: 8px; }

    .muted { opacity: 0.6; font-size: 14px; }

    @media (max-width: 760px) {
      .heroGrid { grid-template-columns: 1fr; }
      .threeCol { grid-template-columns: 1fr; }
      .twoCol { grid-template-columns: 1fr; }
      h1 { font-size: 34px; }
    }

    /* Global styles for dynamically injected event rows */
    :global(.eventRow) {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    :global(.eventDate) {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 36px;
      background: var(--wine);
      color: #fff;
      border-radius: 8px;
      padding: 4px 6px;
      line-height: 1.1;
    }

    :global(.md) { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
    :global(.dy) { font-size: 20px; font-weight: 700; }

    :global(.eventInfo) { flex: 1; }
    :global(.eventName) { font-weight: 700; font-size: 14px; margin: 0 0 2px; }
    :global(.eventMeta) { font-size: 12px; opacity: 0.7; }
    :global(.dot) { margin: 0 3px; }
  </style>
</BaseLayout>
